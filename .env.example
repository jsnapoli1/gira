# Zira Configuration
# Copy to .env and fill in values

# Server
PORT=8080

# Database
DB_PATH=~/.config/zira/zira.db
DATA_DIR=~/.config/zira

# Authentication
JWT_SECRET=change-me-in-production

# Gitea Integration (optional)
GITEA_URL=https://your-gitea-instance.com
GITEA_API_KEY=your-api-token
GITEA_INSECURE_TLS=false
